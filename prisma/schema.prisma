// Monetiq AI — Schéma Prisma
// Base : PostgreSQL (Supabase, Neon, RDS, etc.)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────
// AUTH (NextAuth-compatible)
// ──────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?

  role          UserRole  @default(CREATOR)
  plan          Plan      @default(FREE)
  credits       Int       @default(50)
  preferredLang String    @default("fr")
  country       String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSeenAt    DateTime?

  accounts          Account[]
  sessions          Session[]
  socialAccounts    SocialAccount[]
  audits            Audit[]
  reports           Report[]
  agencyClients     AgencyClient[] @relation("AgencyOwner")
  payments          Payment[]
  subscription      Subscription?
  notifications     Notification[]
  generatedContents GeneratedContent[]

  @@index([email])
}

enum UserRole {
  CREATOR
  INFLUENCER
  AGENCY
  ADMIN
}

enum Plan {
  FREE
  PRO
  AGENCY
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────────────────────────────────────────
// COMPTES SOCIAUX CONNECTÉS
// ──────────────────────────────────────────────

enum Platform {
  FACEBOOK
  TIKTOK
  INSTAGRAM // futur
  YOUTUBE   // futur
}

model SocialAccount {
  id           String   @id @default(cuid())
  userId       String
  platform     Platform
  externalId   String   // Page ID Facebook ou User ID TikTok
  handle       String   // @afroviral.media
  displayName  String?
  avatarUrl    String?
  country      String?
  niche        String?
  followers    Int      @default(0)
  isConnected  Boolean  @default(true)

  accessToken  String?  @db.Text
  refreshToken String?  @db.Text
  scope        String?
  tokenExpires DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  audits Audit[]

  @@unique([platform, externalId])
  @@index([userId])
}

// ──────────────────────────────────────────────
// AUDITS IA
// ──────────────────────────────────────────────

enum AuditStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

enum AuditMode {
  QUICK
  COMPLETE
  AGENCY
}

model Audit {
  id              String       @id @default(cuid())
  userId          String
  socialAccountId String
  status          AuditStatus  @default(PENDING)
  mode            AuditMode    @default(COMPLETE)

  scoreGlobal       Int?
  scoreMonetization Int?
  scoreViral        Int?
  scoreRisk         Int?
  scoreEngagement   Int?

  // Dimensions détaillées (JSON pour flexibilité)
  dimensions      Json?
  issues          Json?
  recommendations Json?
  estimates       Json?

  startedAt   DateTime  @default(now())
  completedAt DateTime?

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  reports       Report[]

  @@index([userId])
  @@index([status])
}

// ──────────────────────────────────────────────
// AGENCE
// ──────────────────────────────────────────────

model AgencyClient {
  id           String  @id @default(cuid())
  agencyUserId String
  name         String
  email        String?
  country      String?
  notes        String?

  createdAt DateTime @default(now())
  agency    User     @relation("AgencyOwner", fields: [agencyUserId], references: [id], onDelete: Cascade)

  @@index([agencyUserId])
}

// ──────────────────────────────────────────────
// CONTENU IA GÉNÉRÉ
// ──────────────────────────────────────────────

enum ContentKind {
  IDEA
  HOOK
  SCRIPT
  CAPTION
  THUMBNAIL
  IMAGE
  VOICEOVER
  REEL
}

model GeneratedContent {
  id        String      @id @default(cuid())
  userId    String
  kind      ContentKind
  prompt    String?     @db.Text
  output    Json
  niche     String?
  country   String?
  model     String?     // claude-opus-4-7, gpt-5, gemini-2.5, elevenlabs-multilingual-v2, runway-gen-4
  tokens    Int?
  cost      Float?

  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, kind])
}

// ──────────────────────────────────────────────
// RAPPORTS PDF
// ──────────────────────────────────────────────

model Report {
  id        String   @id @default(cuid())
  userId    String
  auditId   String?
  title     String
  url       String?  // S3 / Cloudflare R2 URL
  pages     Int      @default(1)
  type      String   // "audit", "roadmap", "anti-ban", "benchmark"
  branded   Boolean  @default(false)

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  audit     Audit?   @relation(fields: [auditId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// ──────────────────────────────────────────────
// PAIEMENTS
// ──────────────────────────────────────────────

enum PaymentProvider {
  STRIPE
  PAYPAL
  WAVE
  ORANGE_MONEY
  MTN_MOMO
  MOOV_MONEY
  FREE_MONEY
  PAYDUNYA
  CINETPAY
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

model Payment {
  id          String          @id @default(cuid())
  userId      String
  provider    PaymentProvider
  externalId  String?
  amount      Float
  currency    String          @default("XOF")
  status      PaymentStatus   @default(PENDING)
  description String?

  createdAt   DateTime @default(now())
  paidAt      DateTime?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subscription {
  id            String   @id @default(cuid())
  userId        String   @unique
  plan          Plan
  provider      PaymentProvider
  externalId    String?
  status        String   @default("active") // active, past_due, canceled
  currentPeriodEnd DateTime
  cancelAtPeriodEnd Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ──────────────────────────────────────────────
// NOTIFICATIONS / WEBHOOKS
// ──────────────────────────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // "audit_completed", "ban_risk_alert", "new_trend", "payment_success"
  title     String
  body      String?
  read      Boolean  @default(false)
  meta      Json?

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

// ──────────────────────────────────────────────
// CPM AFRIQUE (référentiel)
// ──────────────────────────────────────────────

model CountryCpm {
  id           String  @id @default(cuid())
  code         String  @unique // SN, CI, NG…
  name         String
  currency     String
  fxToUsd      Float
  cpmFacebook  Float
  cpmTikTok    Float
  rpmFacebook  Float
  rpmTikTok    Float
  updatedAt    DateTime @updatedAt
}
