# ────────────────────────────────────────────
# Monetiq AI — Variables d'environnement
# ────────────────────────────────────────────

# ─── Supabase (auth + DB + storage) ───
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJI..."          # secret — ne jamais exposer côté browser
SUPABASE_PROJECT_REF="YOUR-PROJECT-REF"

# Optionnel : connexion directe Postgres (pour Prisma / migrations CLI)
# Format pooler : postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=""

# ─── Auth NextAuth (legacy — désactivable si on utilise Supabase Auth seul) ───
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="changeme-use-openssl-rand-base64-32"

# OAuth providers (utilisés par Supabase Auth ou NextAuth)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Meta Graph API (audit Facebook)
META_APP_ID=""
META_APP_SECRET=""
META_GRAPH_API_VERSION="v21.0"

# TikTok Display API + Content Posting API
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# Fournisseurs IA
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
RUNWAY_API_KEY=""
ELEVENLABS_API_KEY=""
STABILITY_API_KEY=""

# Paiements
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""

# Paiements mobile money africains (agrégateurs)
PAYDUNYA_MASTER_KEY=""
PAYDUNYA_PRIVATE_KEY=""
PAYDUNYA_TOKEN=""
WAVE_API_KEY=""
ORANGE_MONEY_API_KEY=""
MTN_MOMO_API_KEY=""
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""

# Storage
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-west-3"
AWS_S3_BUCKET=""

# Email
RESEND_API_KEY=""
EMAIL_FROM="Monetiq AI <hello@monetiq.ai>"

# Observabilité
SENTRY_DSN=""
POSTHOG_KEY=""
