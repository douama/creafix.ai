# ────────────────────────────────────────────
# Monetiq AI — Variables d'environnement
# ────────────────────────────────────────────

# ─── Supabase (auth + DB + storage) ───
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx"
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJI..."          # secret — ne jamais exposer côté browser
SUPABASE_PROJECT_REF="YOUR-PROJECT-REF"

# Optionnel : connexion directe Postgres (pour Prisma / migrations CLI)
# Format pooler : postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=""

# ─── Auth NextAuth (legacy — désactivable si on utilise Supabase Auth seul) ───
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="changeme-use-openssl-rand-base64-32"

# OAuth providers (utilisés par Supabase Auth ou NextAuth)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Meta Graph API (audit Facebook)
META_APP_ID=""
META_APP_SECRET=""
META_GRAPH_API_VERSION="v21.0"

# TikTok Display API + Content Posting API
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""

# Fournisseurs IA
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GOOGLE_AI_API_KEY=""
RUNWAY_API_KEY=""
ELEVENLABS_API_KEY=""
STABILITY_API_KEY=""

# ─── PAIEMENTS ─────────────────────────────────────────────────────
# Active les 4 providers ci-dessous en remplissant leurs clés.
# URL canonique de l'app (utilisée pour return_url, notify_url, callbacks)
NEXT_PUBLIC_APP_URL="https://creafix-ai.vercel.app"

# 1. Stripe — cartes internationales (Visa, MC, Amex)
# Dashboard : https://dashboard.stripe.com/apikeys
# Webhook   : https://creafix-ai.vercel.app/api/webhooks/stripe
STRIPE_SECRET_KEY=""               # sk_live_xxx ou sk_test_xxx
STRIPE_WEBHOOK_SECRET=""           # whsec_xxx (depuis le webhook endpoint Stripe)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""  # pk_live_xxx ou pk_test_xxx

# 2. PayPal — comptes PayPal + cartes via PayPal
# Dashboard : https://developer.paypal.com/dashboard/applications
# Webhook   : https://creafix-ai.vercel.app/api/webhooks/paypal
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_ENV="sandbox"               # "sandbox" en dev, "live" en prod
PAYPAL_WEBHOOK_ID=""               # ID du webhook créé dans PayPal Dashboard

# 3. CinetPay — Mobile Money zone CFA + cartes
# Dashboard : https://app.cinetpay.com
# Webhook   : https://creafix-ai.vercel.app/api/webhooks/cinetpay
# Channels  : Orange Money, MTN MoMo, Moov, Wave, Visa, Mastercard
# Devises   : XOF, XAF, CDF, GNF
CINETPAY_API_KEY=""
CINETPAY_SITE_ID=""

# 4. Flutterwave — Mobile Money/cartes Naira/KES/ZAR (anglophone Africa)
# Dashboard : https://dashboard.flutterwave.com
# Webhook   : https://creafix-ai.vercel.app/api/webhooks/flutterwave
# Channels  : M-Pesa, MTN, Card, USSD, Bank Transfer
# Devises   : NGN, KES, ZAR, GHS, UGX, EGP, USD, EUR
FLUTTERWAVE_SECRET_KEY=""          # FLWSECK_LIVE-xxx ou FLWSECK_TEST-xxx
FLUTTERWAVE_WEBHOOK_HASH=""        # Secret hash configuré dans le Dashboard

# Storage
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-west-3"
AWS_S3_BUCKET=""

# Email
RESEND_API_KEY=""
EMAIL_FROM="Monetiq AI <hello@monetiq.ai>"

# Observabilité
SENTRY_DSN=""
POSTHOG_KEY=""

# ─── Vercel Cron Jobs ───────────────────────────────────────────────────────
# Vercel injecte automatiquement ce header sur /api/cron/* en production.
# En développement local, générer avec : openssl rand -base64 32
# Configurer dans Vercel Dashboard → Project → Settings → Environment Variables
CRON_SECRET=""
